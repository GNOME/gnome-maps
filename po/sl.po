#: src/utils.js:353
#, javascript-format
msgid "%s mi"
msgstr "%s mi"

#. Translators: This is a distance measured in feet
#: src/utils.js:356
#, javascript-format
msgid "%s ft"
msgstr "%s ft"

#. Translators: This is a distance measured in kilometers
#: src/utils.js:364
#, javascript-format
msgid "%s km"
msgstr "%s km"

#. Translators: This is a distance measured in meters
#: src/utils.js:367
#, javascript-format
msgid "%s m"
msgstr "%s m"
